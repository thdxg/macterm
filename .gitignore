.DS_Store
/.vscode
xcuserdata/
DerivedData/
.netrc
GhosttyKit.xcframework

# Ghostty resources downloaded by setup.sh from the thdxg/ghostty release,
# mirroring a real Ghostty.app layout (ghostty/{themes,shell-integration} plus a
# sibling terminfo/). The directory is committed (via .gitkeep) so it exists on
# clone, but its downloaded contents are never committed — ignore everything
# inside except the .gitkeep.
/Macterm/Resources/*
!/Macterm/Resources/.gitkeep
/build
.agents/
.claude/
.codegraph/
*.dmg
appcast*.xml
macterm_run.log
output.log

# Generated by xcodegen from project.yml; we don't commit it so the spec is
# the single source of truth (avoids merge conflicts on the binary plist).
Macterm.xcodeproj/

# Sparkle tooling — downloaded locally for key generation / appcast work.
/bin
private_key.txt
sparkle.tar.xz
sparkle/

docs/brainstorms/
docs/plans/
